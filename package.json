{
  "name": "evolvo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.28.0"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:migrate:deploy": "prisma migrate deploy --config prisma.config.ts",
    "db:migrate:dev": "prisma migrate dev --config prisma.config.ts",
    "db:status": "prisma migrate status --config prisma.config.ts",
    "db:studio": "prisma studio --config prisma.config.ts",
    "db:validate": "prisma validate --config prisma.config.ts",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "github:labels:plan": "pnpm --filter @evolvo/github labels:plan",
    "github:labels:sync": "pnpm --filter @evolvo/github labels:sync",
    "lint": "turbo run lint",
    "services:down": "docker compose --env-file .env -f infra/compose/local-services.compose.yaml down --remove-orphans",
    "services:logs": "docker compose --env-file .env -f infra/compose/local-services.compose.yaml logs --tail=100",
    "services:ps": "docker compose --env-file .env -f infra/compose/local-services.compose.yaml ps",
    "services:up": "docker compose --env-file .env -f infra/compose/local-services.compose.yaml up -d",
    "services:validate": "docker compose --env-file .env -f infra/compose/local-services.compose.yaml config --quiet",
    "test": "vitest run --config vitest.config.mjs infra/**/*.test.mjs && turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@evolvo/eslint-config": "workspace:*",
    "@evolvo/typescript-config": "workspace:*",
    "@evolvo/vitest-config": "workspace:*",
    "@types/node": "^24.5.2",
    "dotenv": "^17.2.2",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "prisma": "^7.0.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "yaml": "^2.8.1"
  }
}
