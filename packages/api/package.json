{
  "name": "@evolvo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./attempt-record": "./src/attempt-record.ts",
    "./client": "./src/client.ts",
    "./database-url": "./src/database-url.ts",
    "./github-audit-event": "./src/github-audit-event.ts",
    "./issue-record": "./src/issue-record.ts",
    "./model-invocation": "./src/model-invocation.ts",
    "./worktree-record": "./src/worktree-record.ts"
  },
  "scripts": {
    "build": "pnpm --dir ../.. db:generate && tsc --noEmit -p tsconfig.json",
    "clean": "git clean -fdX .",
    "db:generate": "pnpm --dir ../.. db:generate",
    "db:migrate:deploy": "pnpm --dir ../.. db:migrate:deploy",
    "db:migrate:dev": "pnpm --dir ../.. db:migrate:dev",
    "db:status": "pnpm --dir ../.. db:status",
    "db:studio": "pnpm --dir ../.. db:studio",
    "db:validate": "pnpm --dir ../.. db:validate",
    "lint": "eslint . --max-warnings 0 --no-error-on-unmatched-pattern",
    "test": "pnpm --dir ../.. db:generate && vitest run --config ../../vitest.config.mjs",
    "typecheck": "pnpm --dir ../.. db:generate && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@evolvo/typescript-config": "workspace:*"
  }
}
