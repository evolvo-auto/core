{
  "name": "@evolvo/benchmarks",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./registry": "./src/registry.ts",
    "./runner": "./src/runner.ts"
  },
  "scripts": {
    "build": "pnpm --dir ../.. db:generate && tsc --noEmit -p tsconfig.json",
    "clean": "git clean -fdX .",
    "lint": "eslint . --max-warnings 0 --no-error-on-unmatched-pattern",
    "test": "pnpm --dir ../.. db:generate && vitest run --root . --config ../../vitest.config.mjs",
    "typecheck": "pnpm --dir ../.. db:generate && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@evolvo/api": "workspace:*",
    "@evolvo/challenges": "workspace:*",
    "@evolvo/schemas": "workspace:*"
  },
  "devDependencies": {
    "@evolvo/typescript-config": "workspace:*",
    "@types/node": "^24.5.2"
  }
}
