{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "DASHBOARD_PORT",
    "GITHUB_OWNER",
    "GITHUB_REPO",
    "GITHUB_TOKEN",
    "POSTGRES_DB",
    "POSTGRES_HOST",
    "POSTGRES_PASSWORD",
    "POSTGRES_PORT",
    "POSTGRES_SCHEMA",
    "POSTGRES_USER",
    "RUNTIME_HEALTH_URL",
    "RUNTIME_BASE_REF",
    "RUNTIME_GIT_REMOTE",
    "RUNTIME_LOOP_INTERVAL_MS",
    "RUNTIME_MAX_REPAIR_ATTEMPTS",
    "RUNTIME_PORT",
    "RUNTIME_SMOKE_BASE_URL",
    "RUNTIME_SMOKE_USE_PLAYWRIGHT",
    "RUNTIME_WORKTREES_ROOT",
    "SUPERVISOR_HEALTH_URL",
    "SUPERVISOR_PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    }
  }
}
